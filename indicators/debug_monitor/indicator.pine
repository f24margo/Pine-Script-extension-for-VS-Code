//@version=5
// ╔══════════════════════════════════════════════════════════════════╗
// ║  APEX V3.9.5 — REPLAY DEBUG MONITOR                            ║
// ║  Двойная панель для пошаговой отладки в режиме Replay           ║
// ║                                                                  ║
// ║  ЛЕВАЯ ПАНЕЛЬ  → РАБОЧИЕ значения (что видит пользователь)      ║
// ║  ПРАВАЯ ПАНЕЛЬ → ОТЛАДОЧНЫЕ значения (почему система так решила) ║
// ╚══════════════════════════════════════════════════════════════════╝

indicator(
     "APEX V3.9.5 — Replay Debug Monitor",
     overlay    = true,
     max_boxes_count = 50,
     max_lines_count = 20)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 0. ПАРАМЕТРЫ
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

i_lookback = input.int(40, "IPDA Lookback", options=[20, 40, 60],
     group="Основные параметры")

bool i_show_repaint_diff = input.bool(true,
     "Показывать расхождение BAD vs FIX",
     group="Отладка",
     tooltip="Красная/зелёная линия weekly уровней + diff в панели")

bool i_show_macro = input.bool(true,
     "Показывать макро блок",
     group="Отладка")

bool i_show_ipda = input.bool(true,
     "Показывать IPDA блок",
     group="Отладка")

bool i_show_sweep = input.bool(true,
     "Показывать Weekly Sweep блок",
     group="Отладка")

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 1. БЛОК МАКРО (Block 2 оригинала)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

float dxy_price = request.security("TVC:DXY",   "60", close,
     barmerge.gaps_off, barmerge.lookahead_off)
float spx_price = request.security("SP:SPX",    "60", close,
     barmerge.gaps_off, barmerge.lookahead_off)
float us10y     = request.security("TVC:US10Y", "60", close,
     barmerge.gaps_off, barmerge.lookahead_off)

float dxy_sma   = ta.sma(dxy_price, 24)
float spx_sma   = ta.sma(spx_price, 24)

string dxy_trend  = dxy_price > dxy_sma ? "BULLISH" : "BEARISH"
string spx_trend  = spx_price > spx_sma ? "RISK-ON" : "RISK-OFF"

// Промежуточные значения для отладки
float dxy_dist_pct = dxy_sma != 0 ?
     (dxy_price - dxy_sma) / dxy_sma * 100 : 0.0
float spx_dist_pct = spx_sma != 0 ?
     (spx_price - spx_sma) / spx_sma * 100 : 0.0

bool macro_ok = dxy_trend == "BEARISH" and spx_trend == "RISK-ON"

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 2. БЛОК WEEKLY SWEEP (Block 3 оригинала — с багом и без)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ── ОРИГИНАЛ V3.9.5 (lookahead_on = баг) ──
float w_h_BAD = request.security(syminfo.tickerid, "W", high,
     barmerge.gaps_off, barmerge.lookahead_on)
float w_l_BAD = request.security(syminfo.tickerid, "W", low,
     barmerge.gaps_off, barmerge.lookahead_on)

// ── ИСПРАВЛЕННАЯ ВЕРСИЯ (lookahead_off) ──
float w_h_FIX = request.security(syminfo.tickerid, "W", high[1],
     barmerge.gaps_off, barmerge.lookahead_off)
float w_l_FIX = request.security(syminfo.tickerid, "W", low[1],
     barmerge.gaps_off, barmerge.lookahead_off)

// Расхождение
float atr       = ta.atr(14)
float diff_h    = math.abs(w_h_BAD - w_h_FIX)
float diff_l    = math.abs(w_l_BAD - w_l_FIX)
float diff_max  = math.max(diff_h, diff_l)
float diff_atr  = atr > 0 ? diff_max / atr : 0.0
bool  repainting = diff_atr > 0.05

// Касания уровней
bool touch_wh = high >= w_h_BAD
bool touch_wl = low  <= w_l_BAD

// Состояние sweep (сброс каждую неделю)
var bool weekly_sweep_hit = false
if ta.change(time("W"))
    weekly_sweep_hit := false
if touch_wh or touch_wl
    weekly_sweep_hit := true

// День недели текущего бара (для контекста)
int day_of_week = dayofweek               // 1=Вс, 2=Пн ... 7=Сб
string dow_str  = day_of_week == 2 ? "ПН" :
                  day_of_week == 3 ? "ВТ" :
                  day_of_week == 4 ? "СР" :
                  day_of_week == 5 ? "ЧТ" :
                  day_of_week == 6 ? "ПТ" : "ВЫХ"

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 3. БЛОК IPDA (Block 4 оригинала)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

float h_range   = ta.highest(high[1], i_lookback)
float l_range   = ta.lowest(low[1],   i_lookback)
float eq        = (h_range + l_range) / 2.0
float range_sz  = h_range - l_range

// Позиция цены в диапазоне (0% = дно, 100% = топ)
float pos_pct   = range_sz > 0 ?
     (close - l_range) / range_sz * 100 : 50.0

bool in_discount = close < eq
bool in_premium  = close >= eq

// Расстояние до EQ
float dist_to_eq     = close - eq
float dist_to_eq_pct = range_sz > 0 ?
     math.abs(dist_to_eq) / range_sz * 100 : 0.0

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 4. ИТОГОВЫЙ ВЕРДИКТ
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Условия для сигнала (логика V3.9.5)
bool long_setup  = macro_ok and in_discount and weekly_sweep_hit
bool short_setup = not macro_ok and in_premium and weekly_sweep_hit

string verdict     = long_setup  ? "▲ LONG SETUP"  :
                     short_setup ? "▼ SHORT SETUP" :
                     macro_ok    ? "WAIT (нет sweep/IPDA)" :
                                   "AVOID (макро против)"
color  verdict_col = long_setup  ? color.lime   :
                     short_setup ? color.red     :
                     macro_ok    ? color.orange  : color.gray

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 5. ВИЗУАЛИЗАЦИЯ НА ГРАФИКЕ
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Weekly уровни: красный = BAD (lookahead_on), зелёный = FIX
plot(w_h_BAD, "W-High ORIGINAL",
     color=color.new(color.red,  20),
     linewidth=2, style=plot.style_stepline)
plot(w_h_FIX, "W-High FIXED",
     color=color.new(color.lime, 20),
     linewidth=2, style=plot.style_stepline)
plot(w_l_BAD, "W-Low ORIGINAL",
     color=color.new(color.red,  50),
     linewidth=1, style=plot.style_stepline)
plot(w_l_FIX, "W-Low FIXED",
     color=color.new(color.lime, 50),
     linewidth=1, style=plot.style_stepline)

// IPDA Equilibrium
plot(eq, "EQ",
     color=color.new(color.gray, 40),
     linewidth=1, style=plot.style_dashed)

// Фон: зона discount/premium
bgcolor(in_discount ? color.new(color.teal, 93) : na, title="Discount Zone")
bgcolor(in_premium  ? color.new(color.red,  93) : na, title="Premium Zone")

// Repainting зона
bgcolor(repainting  ? color.new(color.yellow, 88) : na, title="Repainting Active")

// Маркеры касания weekly уровней
plotshape(touch_wl, "W-Low Touch",
     shape.triangleup, location.belowbar,
     color.teal, size=size.small)
plotshape(touch_wh, "W-High Touch",
     shape.triangledown, location.abovebar,
     color.maroon, size=size.small)

// Сигнальные метки
plotshape(long_setup  and not long_setup[1],  "LONG SETUP",
     shape.labelup,   location.belowbar,
     color.lime, text="▲ L", textcolor=color.black, size=size.normal)
plotshape(short_setup and not short_setup[1], "SHORT SETUP",
     shape.labeldown, location.abovebar,
     color.red,  text="▼ S", textcolor=color.white, size=size.normal)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 6. ЛЕВАЯ ПАНЕЛЬ — РАБОЧИЕ ЗНАЧЕНИЯ
//    Что видит пользователь: итоговые состояния системы
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var table panel_work = table.new(
     position.top_left, 2, 10,
     bgcolor      = color.new(color.black, 55),
     border_width = 1,
     border_color = color.new(color.gray, 50),
     frame_width  = 1,
     frame_color  = color.new(color.gray, 30))

if barstate.islast or barstate.isrealtime

    // ── Заголовок ──
    table.cell(panel_work, 0, 0, "◉ РАБОЧАЯ ПАНЕЛЬ",
         bgcolor    = color.new(color.navy, 20),
         text_color = color.white,
         text_size  = size.small,
         colspan    = 2)

    // ── Вердикт ──
    table.cell(panel_work, 0, 1, "СТАТУС",
         text_color = color.white,
         text_size  = size.small)
    table.cell(panel_work, 1, 1, verdict,
         bgcolor    = color.new(verdict_col, 30),
         text_color = verdict_col,
         text_size  = size.small)

    // ── DXY ──
    color c_dxy = dxy_trend == "BEARISH" ? color.teal : color.red
    table.cell(panel_work, 0, 2, "DXY",
         text_color = color.white, text_size = size.small)
    table.cell(panel_work, 1, 2, dxy_trend,
         bgcolor    = color.new(c_dxy, 50),
         text_color = c_dxy, text_size = size.small)

    // ── SPX ──
    color c_spx = spx_trend == "RISK-ON" ? color.teal : color.red
    table.cell(panel_work, 0, 3, "S&P 500",
         text_color = color.white, text_size = size.small)
    table.cell(panel_work, 1, 3, spx_trend,
         bgcolor    = color.new(c_spx, 50),
         text_color = c_spx, text_size = size.small)

    // ── US10Y ──
    table.cell(panel_work, 0, 4, "US10Y",
         text_color = color.white, text_size = size.small)
    table.cell(panel_work, 1, 4,
         str.tostring(us10y, "#.##") + "%",
         text_color = color.white, text_size = size.small)

    // ── IPDA зона ──
    color c_ipda = in_discount ? color.teal : color.red
    table.cell(panel_work, 0, 5, "IPDA ZONE",
         text_color = color.white, text_size = size.small)
    table.cell(panel_work, 1, 5,
         in_discount ? "DISCOUNT" : "PREMIUM",
         bgcolor    = color.new(c_ipda, 50),
         text_color = c_ipda, text_size = size.small)

    // ── Weekly Sweep ──
    color c_sw = weekly_sweep_hit ? color.orange : color.gray
    table.cell(panel_work, 0, 6, "W-SWEEP",
         text_color = color.white, text_size = size.small)
    table.cell(panel_work, 1, 6,
         weekly_sweep_hit ? "HIT ✓" : "NOT REACHED",
         bgcolor    = color.new(c_sw, 60),
         text_color = c_sw, text_size = size.small)

    // ── Macro OK ──
    color c_mac = macro_ok ? color.lime : color.red
    table.cell(panel_work, 0, 7, "MACRO OK",
         text_color = color.white, text_size = size.small)
    table.cell(panel_work, 1, 7,
         macro_ok ? "YES" : "NO",
         bgcolor    = color.new(c_mac, 50),
         text_color = c_mac, text_size = size.small)

    // ── Текущий день недели ──
    table.cell(panel_work, 0, 8, "ДЕНЬ",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_work, 1, 8, dow_str,
         text_color = color.gray, text_size = size.tiny)

    // ── ATR ──
    table.cell(panel_work, 0, 9, "ATR(14)",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_work, 1, 9,
         str.tostring(math.round(atr, 2)),
         text_color = color.gray, text_size = size.tiny)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 7. ПРАВАЯ ПАНЕЛЬ — ОТЛАДОЧНЫЕ ЗНАЧЕНИЯ
//    Почему система решила именно так: промежуточные данные
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var table panel_debug = table.new(
     position.top_right, 2, 16,
     bgcolor      = color.new(color.black, 55),
     border_width = 1,
     border_color = color.new(color.gray, 50),
     frame_width  = 1,
     frame_color  = color.new(color.purple, 40))

if barstate.islast or barstate.isrealtime

    // ── Заголовок ──
    table.cell(panel_debug, 0, 0, "⚙ ОТЛАДОЧНАЯ ПАНЕЛЬ",
         bgcolor    = color.new(color.purple, 30),
         text_color = color.white,
         text_size  = size.small,
         colspan    = 2)

    // ── БЛОК 2: MACRO ──────────────────────────────────────
    table.cell(panel_debug, 0, 1, "── MACRO ──",
         bgcolor    = color.new(color.navy, 60),
         text_color = color.new(color.blue, 20),
         text_size  = size.tiny,
         colspan    = 2)

    // DXY цена vs SMA
    table.cell(panel_debug, 0, 2, "DXY / SMA24",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 2,
         str.tostring(math.round(dxy_price, 2)) + " / " +
         str.tostring(math.round(dxy_sma, 2)),
         text_color = color.white, text_size = size.tiny)

    // DXY отклонение
    color c_dxy_d = dxy_dist_pct < 0 ? color.teal : color.red
    table.cell(panel_debug, 0, 3, "DXY откл %",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 3,
         (dxy_dist_pct >= 0 ? "+" : "") +
         str.tostring(math.round(dxy_dist_pct, 3)) + "%",
         text_color = c_dxy_d, text_size = size.tiny)

    // SPX отклонение
    color c_spx_d = spx_dist_pct > 0 ? color.teal : color.red
    table.cell(panel_debug, 0, 4, "SPX откл %",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 4,
         (spx_dist_pct >= 0 ? "+" : "") +
         str.tostring(math.round(spx_dist_pct, 3)) + "%",
         text_color = c_spx_d, text_size = size.tiny)

    // ── БЛОК 3: WEEKLY SWEEP ───────────────────────────────
    table.cell(panel_debug, 0, 5, "── BLOCK 3: SWEEP ──",
         bgcolor    = color.new(color.navy, 60),
         text_color = color.new(color.blue, 20),
         text_size  = size.tiny,
         colspan    = 2)

    // W-High BAD vs FIX
    color c_wh = diff_h > atr * 0.05 ? color.red : color.lime
    table.cell(panel_debug, 0, 6, "W-H BAD / FIX",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 6,
         str.tostring(math.round(w_h_BAD, 2)) + " / " +
         str.tostring(math.round(w_h_FIX, 2)),
         text_color = c_wh, text_size = size.tiny)

    // W-Low BAD vs FIX
    color c_wl = diff_l > atr * 0.05 ? color.red : color.lime
    table.cell(panel_debug, 0, 7, "W-L BAD / FIX",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 7,
         str.tostring(math.round(w_l_BAD, 2)) + " / " +
         str.tostring(math.round(w_l_FIX, 2)),
         text_color = c_wl, text_size = size.tiny)

    // Расхождение
    color c_diff = repainting ? color.red : color.lime
    table.cell(panel_debug, 0, 8, "DIFF (ATR)",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 8,
         str.tostring(math.round(diff_atr, 4)) + " ATR" +
         (repainting ? "  ⚠" : "  ✓"),
         bgcolor    = repainting ? color.new(color.red, 70) : color.new(color.teal, 70),
         text_color = c_diff, text_size = size.tiny)

    // Касание в этом баре
    string touch_now = touch_wh ? "HIGH ▼" : touch_wl ? "LOW ▲" : "—"
    color c_touch = (touch_wh or touch_wl) ? color.orange : color.gray
    table.cell(panel_debug, 0, 9, "TOUCH NOW",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 9, touch_now,
         text_color = c_touch, text_size = size.tiny)

    // ── БЛОК 4: IPDA ───────────────────────────────────────
    table.cell(panel_debug, 0, 10, "── BLOCK 4: IPDA ──",
         bgcolor    = color.new(color.navy, 60),
         text_color = color.new(color.blue, 20),
         text_size  = size.tiny,
         colspan    = 2)

    // High / Low диапазона
    table.cell(panel_debug, 0, 11, "Range H/L",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 11,
         str.tostring(math.round(h_range, 2)) + " / " +
         str.tostring(math.round(l_range, 2)),
         text_color = color.white, text_size = size.tiny)

    // Equilibrium
    table.cell(panel_debug, 0, 12, "EQ",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 12,
         str.tostring(math.round(eq, 2)),
         text_color = color.white, text_size = size.tiny)

    // Позиция цены в диапазоне
    color c_pos = pos_pct < 30 ? color.teal :
                  pos_pct > 70 ? color.red  : color.orange
    table.cell(panel_debug, 0, 13, "Позиция в %",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 13,
         str.tostring(math.round(pos_pct, 1)) + "%" +
         "  (" + (in_discount ? "DISC" : "PREM") + ")",
         text_color = c_pos, text_size = size.tiny)

    // Расстояние до EQ
    table.cell(panel_debug, 0, 14, "До EQ",
         text_color = color.gray, text_size = size.tiny)
    table.cell(panel_debug, 1, 14,
         (dist_to_eq >= 0 ? "+" : "") +
         str.tostring(math.round(dist_to_eq, 2)) + " pts" +
         "  (" + str.tostring(math.round(dist_to_eq_pct, 1)) + "%)",
         text_color = color.white, text_size = size.tiny)

    // ── ИТОГ логики ────────────────────────────────────────
    table.cell(panel_debug, 0, 15, "CONFLUENCE",
         bgcolor    = color.new(color.black, 30),
         text_color = color.gray, text_size = size.tiny)
    string conf_str = (macro_ok ? "M✓" : "M✗") + " " +
                      (in_discount or in_premium ? "I✓" : "I✗") + " " +
                      (weekly_sweep_hit ? "S✓" : "S✗")
    color c_conf = long_setup or short_setup ? color.lime : color.gray
    table.cell(panel_debug, 1, 15, conf_str,
         bgcolor    = color.new(color.black, 30),
         text_color = c_conf, text_size = size.tiny)
