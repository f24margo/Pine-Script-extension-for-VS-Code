//@version=6
strategy(
     "APEX V3.9.5 Strategy Tester",
     overlay            = true,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     calc_on_every_tick = false,
     max_bars_back      = 500)

// ============================================================
// 0. INPUTS
// ============================================================

// --- Core ---
i_lookback = input.int(40, "IPDA Lookback", options=[20, 40, 60], group="Core")

// --- Stop/TP Engine ---
bool i_use_sl_tp  = input.bool(false, "Use SL/TP Filter", group="Stop/TP Engine")  // Нова кнопка для вмикання/вимикання SL/TP як фільтра
string i_sl_mode  = input.string("ATR", "SL/TP Mode",
     options=["ATR", "VWAP", "ADX"], group="Stop/TP Engine")

float i_atr_sl    = input.float(1.5, "ATR SL mult",  group="Stop/TP Engine", step=0.25, minval=0.25)
float i_atr_tp1   = input.float(1.5, "ATR TP1 mult", group="Stop/TP Engine", step=0.25, minval=0.25)
float i_atr_tp2   = input.float(3.0, "ATR TP2 mult", group="Stop/TP Engine", step=0.25, minval=0.25)
bool  i_use_tp2   = input.bool(false, "Use TP2 (50% exit at TP1, 50% at TP2)", group="Stop/TP Engine")

// VWAP режим — параметры объявлены, активируются позже
float i_vwap_sl   = input.float(0.618, "VWAP SL sigma", group="Stop/TP Engine [VWAP]", step=0.118)
float i_vwap_tp   = input.float(1.0,   "VWAP TP sigma", group="Stop/TP Engine [VWAP]", step=0.118)

// ADX режим — параметры объявлены, активируются позже
float i_adx_sl_sleep = input.float(0.75, "ADX Sleep SL mult",  group="Stop/TP Engine [ADX]", step=0.25)
float i_adx_sl_trend = input.float(1.5,  "ADX Trend SL mult",  group="Stop/TP Engine [ADX]", step=0.25)
float i_adx_sl_over  = input.float(2.5,  "ADX Over SL mult",   group="Stop/TP Engine [ADX]", step=0.25)

// --- Macro E2 (все выключены — заглушки) ---
bool  i_use_vix   = input.bool(false, "Use VIX Filter",  group="Macro [E2]")
float i_vix_warn  = input.float(25.0, "VIX Warning",     group="Macro [E2]")
float i_vix_panic = input.float(35.0, "VIX Panic",       group="Macro [E2]")
bool  i_use_jpy   = input.bool(false, "Use JPY Filter",  group="Macro [E2]")
float i_jpy_drop  = input.float(3.0,  "JPY Drop % 5D",   group="Macro [E2]")
bool  i_use_move  = input.bool(false, "Use MOVE Filter", group="Macro [E2]")
bool  i_use_ema   = input.bool(false, "Use EMA Confluence (vs SMA24)", group="Macro [E2]")

// --- ADX Engine E3 ---
int   i_adx_len   = input.int(14,    "ADX Length",       group="ADX Engine [E3]")
int   i_adx_min   = input.int(20,    "ADX Trend Min",    group="ADX Engine [E3]")
int   i_adx_max   = input.int(40,    "ADX Overheat",     group="ADX Engine [E3]")
bool  i_use_adx   = input.bool(false, "Use ADX Filter",  group="ADX Engine [E3]")

// --- RVOL E4 ---
int   i_rvol_len  = input.int(20,    "RVOL Lookback",    group="RVOL [E4]")
float i_rvol_min  = input.float(1.5, "RVOL Minimum",     group="RVOL [E4]", step=0.1)
bool  i_use_rvol  = input.bool(false, "Use RVOL Filter", group="RVOL [E4]")

// ============================================================
// 1. MACRO BLOCK
// ============================================================

float dxy_price = request.security("TVC:DXY",   "60", close, barmerge.gaps_off, barmerge.lookahead_off)
float spx_price = request.security("SP:SPX",    "60", close, barmerge.gaps_off, barmerge.lookahead_off)
float us10y     = request.security("TVC:US10Y", "60", close, barmerge.gaps_off, barmerge.lookahead_off)

float dxy_sma   = ta.sma(dxy_price, 24)
float spx_sma   = ta.sma(spx_price, 24)

// E2: EMA конфлюенция — заглушка пока i_use_ema = false
float dxy_ema20 = ta.ema(dxy_price, 20)
float dxy_ema50 = ta.ema(dxy_price, 50)
float spx_ema20 = ta.ema(spx_price, 20)
float spx_ema50 = ta.ema(spx_price, 50)

bool dxy_bear_sma = dxy_price < dxy_sma
bool spx_bull_sma = spx_price > spx_sma
bool dxy_bear_ema = dxy_price < dxy_ema20 and dxy_ema20 < dxy_ema50
bool spx_bull_ema = spx_price > spx_ema20 and spx_ema20 > spx_ema50

bool dxy_bear  = i_use_ema ? dxy_bear_ema : dxy_bear_sma
bool spx_bull  = i_use_ema ? spx_bull_ema : spx_bull_sma
bool macro_ok  = dxy_bear and spx_bull

// ============================================================
// 2. WEEKLY SWEEP BLOCK
// ============================================================

float w_h_FIX = request.security(syminfo.tickerid, "W", high[1], barmerge.gaps_off, barmerge.lookahead_off)
float w_l_FIX = request.security(syminfo.tickerid, "W", low[1],  barmerge.gaps_off, barmerge.lookahead_off)

bool touch_wh = high >= w_h_FIX
bool touch_wl = low  <= w_l_FIX

var bool weekly_sweep_hit = false
if ta.change(time("W")) != 0
    weekly_sweep_hit := false
if touch_wh or touch_wl
    weekly_sweep_hit := true

// ============================================================
// 3. IPDA BLOCK
// ============================================================

float h_range  = ta.highest(high[1], i_lookback)
float l_range  = ta.lowest(low[1],   i_lookback)
float eq       = (h_range + l_range) / 2.0
bool  in_discount = close < eq
bool  in_premium  = close >= eq

// ============================================================
// 4. ATR
// ============================================================

float atr = ta.atr(14)

// ============================================================
// 5. FILTER SKELETONS (заглушки — всегда true пока блок не реализован)
// ============================================================

// E2: Macro extended — заглушка
// Заменишь тело когда будет готов Этап 2
float vix_price  = request.security("CBOE:VIX",   "D", close, barmerge.gaps_off, barmerge.lookahead_off)
float jpy_price  = request.security("FX:USDJPY",  "D", close, barmerge.gaps_off, barmerge.lookahead_off)
float move_price = request.security("CBOE:MOVE",  "D", close, barmerge.gaps_off, barmerge.lookahead_off)

float jpy_5d_ago = nz(jpy_price[5], jpy_price)
bool  jpy_collapse = jpy_5d_ago != 0 and ((jpy_price - jpy_5d_ago) / jpy_5d_ago * 100) <= -i_jpy_drop

bool f_macro_e2 =
     (not i_use_vix  or vix_price < i_vix_panic) and
     (not i_use_jpy  or not jpy_collapse) and
     (not i_use_move or true)  // MOVE логика добавится в E2

// E3: ADX — заглушка
float adx_val = ta.sma(math.abs(ta.change(close)), i_adx_len)  // placeholder, заменится на ta.dmi в E3
bool  f_adx   = not i_use_adx or true  // placeholder

// E4: RVOL — заглушка
float avg_vol = ta.sma(volume, i_rvol_len)
float rvol    = avg_vol > 0 ? volume / avg_vol : 1.0
bool  f_rvol  = not i_use_rvol or rvol >= i_rvol_min

// ============================================================
// 6. CONFLUENCE & DIRECTION
// ============================================================

bool long_ok  = macro_ok and in_discount and weekly_sweep_hit and f_macro_e2 and f_adx and f_rvol
bool short_ok = not macro_ok and in_premium and weekly_sweep_hit and f_macro_e2 and f_adx and f_rvol

bool in_trade = strategy.position_size != 0

bool long_signal  = long_ok  and not long_ok[1]   and not in_trade
bool short_signal = short_ok and not short_ok[1]  and not in_trade

// ============================================================
// 7. STOP/TP CALCULATION
// ============================================================

// ATR режим (активен сейчас)
float sl_dist_atr  = atr * i_atr_sl
float tp1_dist_atr = atr * i_atr_tp1
float tp2_dist_atr = atr * i_atr_tp2

// VWAP режим — skeleton (активируется через i_sl_mode = "VWAP")
float vwap_val     = ta.vwap(close)
float vwap_std     = ta.stdev(close, 20)
float sl_dist_vwap = vwap_std * i_vwap_sl
float tp_dist_vwap = vwap_std * i_vwap_tp

// ADX режим — skeleton (активируется через i_sl_mode = "ADX")
string adx_phase   = adx_val < i_adx_min ? "SLEEP" : adx_val > i_adx_max ? "OVER" : "TREND"
float sl_dist_adx = if adx_phase == "SLEEP"
    atr * i_adx_sl_sleep
else if adx_phase == "OVER"
    atr * i_adx_sl_over
else
    atr * i_adx_sl_trend

// Выбор режима
float sl_dist  = i_sl_mode == "VWAP" ? sl_dist_vwap :
                 i_sl_mode == "ADX"  ? sl_dist_adx  :
                                       sl_dist_atr
float tp1_dist = i_sl_mode == "VWAP" ? tp_dist_vwap : tp1_dist_atr
float tp2_dist = tp2_dist_atr

// Уровни для лонга
float long_sl  = close - sl_dist
float long_tp1 = close + tp1_dist
float long_tp2 = close + tp2_dist

// Уровни для шорта
float short_sl  = close + sl_dist
float short_tp1 = close - tp1_dist
float short_tp2 = close - tp2_dist

// ============================================================
// 8. ENTRIES
// ============================================================

if long_signal
    strategy.entry("LONG", strategy.long, comment="L|" +
         (in_discount ? "DISC" : "PREM") + "|" +
         (weekly_sweep_hit ? "SW+" : "SW-") + "|" +
         "ATR:" + str.tostring(math.round(atr, 1)))

if short_signal
    strategy.entry("SHORT", strategy.short, comment="S|" +
         (in_discount ? "DISC" : "PREM") + "|" +
         (weekly_sweep_hit ? "SW+" : "SW-") + "|" +
         "ATR:" + str.tostring(math.round(atr, 1)))

// ============================================================
// 9. EXITS
// ============================================================

// Stop Loss & TP1
strategy.exit("LONG SL/TP",  "LONG",
     stop   = long_sl,
     limit  = long_tp1,
     qty_percent = i_use_tp2 ? 50 : 100,
     comment = "SL/TP1")

strategy.exit("SHORT SL/TP", "SHORT",
     stop   = short_sl,
     limit  = short_tp1,
     qty_percent = i_use_tp2 ? 50 : 100,
     comment = "SL/TP1")

// TP2 тільки якщо ввімкнено
if i_use_tp2
    strategy.exit("LONG TP2",    "LONG",
         limit  = long_tp2,
         qty_percent = 50,
         comment = "TP2")

    strategy.exit("SHORT TP2",   "SHORT",
         limit  = short_tp2,
         qty_percent = 50,
         comment = "TP2")

// ============================================================
// 10. STATISTICS COUNTERS
// ============================================================

// Накапливаем — данные будут полезны когда включатся фильтры E2-E4
var int cnt_long          = 0
var int cnt_short         = 0
var int cnt_disc          = 0
var int cnt_prem          = 0
var int cnt_macro_blocked = 0  // сколько сигналов заблокировал macro_e2
var int cnt_adx_blocked   = 0  // E3 placeholder
var int cnt_rvol_blocked  = 0  // E4 placeholder

if long_signal
    cnt_long  += 1
    cnt_disc  += in_discount ? 1 : 0
    cnt_prem  += in_premium  ? 1 : 0

if short_signal
    cnt_short += 1
    cnt_disc  += in_discount ? 1 : 0
    cnt_prem  += in_premium  ? 1 : 0

// Считаем сколько потенциальных сигналов зарезали фильтры
bool raw_long  = macro_ok and in_discount and weekly_sweep_hit and not in_trade
bool raw_short = not macro_ok and in_premium and weekly_sweep_hit and not in_trade

if ((raw_long and not raw_long[1]) or (raw_short and not raw_short[1])) and not f_macro_e2
    cnt_macro_blocked += 1
if ((raw_long and not raw_long[1]) or (raw_short and not raw_short[1])) and f_macro_e2 and not f_adx
    cnt_adx_blocked += 1
if ((raw_long and not raw_long[1]) or (raw_short and not raw_short[1])) and f_macro_e2 and f_adx and not f_rvol
    cnt_rvol_blocked += 1

// ============================================================
// 11. VISUALIZATION
// ============================================================

// SL/TP линии текущей позиции
var line l_sl  = na
var line l_tp1 = na
var line l_tp2 = na

if long_signal or short_signal
    if not na(l_sl)
        line.delete(l_sl)
    if not na(l_tp1)
        line.delete(l_tp1)
    if not na(l_tp2)
        line.delete(l_tp2)

    float sl_lvl  = long_signal ? long_sl   : short_sl
    float tp1_lvl = long_signal ? long_tp1  : short_tp1
    float tp2_lvl = long_signal ? long_tp2  : short_tp2

    l_sl  := line.new(bar_index, sl_lvl,  bar_index + 1, sl_lvl,
         color=color.red,  width=1, style=line.style_dashed, extend=extend.right)
    l_tp1 := line.new(bar_index, tp1_lvl, bar_index + 1, tp1_lvl,
         color=color.lime, width=1, extend=extend.right)
    l_tp2 := line.new(bar_index, tp2_lvl, bar_index + 1, tp2_lvl,
         color=color.teal, width=1, style=line.style_dotted, extend=extend.right)

// Сигнальные метки с контекстом
if long_signal
    label.new(bar_index, low,
         "LONG\nDISC:" + (in_discount ? "Y" : "N") +
         " SW:"  + (weekly_sweep_hit ? "Y" : "N") +
         "\nSL:"  + str.tostring(math.round(long_sl,  2)) +
         " TP1:" + str.tostring(math.round(long_tp1, 2)),
         color=color.new(color.lime, 20), textcolor=color.black,
         style=label.style_label_up, size=size.tiny)

if short_signal
    label.new(bar_index, high,
         "SHORT\nPREM:" + (in_premium ? "Y" : "N") +
         " SW:"   + (weekly_sweep_hit ? "Y" : "N") +
         "\nSL:"  + str.tostring(math.round(short_sl,  2)) +
         " TP1:" + str.tostring(math.round(short_tp1, 2)),
         color=color.new(color.red, 20), textcolor=color.white,
         style=label.style_label_down, size=size.tiny)

// Фон зон
bgcolor(in_discount ? color.new(color.teal, 93) : na, title="Discount")
bgcolor(in_premium  ? color.new(color.red,  93) : na, title="Premium")

// EQ линия
plot(eq, "EQ", color=color.new(color.gray, 50), linewidth=1, style=plot.style_line)

// ============================================================
// 12. STATS PANEL
// ============================================================

var table ts = table.new(position.bottom_right, 2, 10,
     bgcolor=color.new(color.black, 55),
     border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    int total = cnt_long + cnt_short

    table.cell(ts, 0, 0, "STRATEGY STATS",  bgcolor=color.new(color.navy, 20), text_color=color.white, text_size=size.small)
    table.cell(ts, 1, 0, i_sl_mode + " mode", bgcolor=color.new(color.navy, 20), text_color=color.gray,  text_size=size.small)

    table.cell(ts, 0, 1, "Total signals",   text_color=color.white, text_size=size.tiny)
    table.cell(ts, 1, 1, str.tostring(total), text_color=color.white, text_size=size.tiny)

    table.cell(ts, 0, 2, "Long / Short",    text_color=color.white, text_size=size.tiny)
    table.cell(ts, 1, 2, str.tostring(cnt_long) + " / " + str.tostring(cnt_short), text_color=color.white, text_size=size.tiny)

    table.cell(ts, 0, 3, "In Discount",     text_color=color.white, text_size=size.tiny)
    table.cell(ts, 1, 3, str.tostring(cnt_disc) + (total > 0 ? "  " + str.tostring(math.round(cnt_disc / total * 100, 1)) + "%" : ""), text_color=color.teal, text_size=size.tiny)

    table.cell(ts, 0, 4, "In Premium",      text_color=color.white, text_size=size.tiny)
    table.cell(ts, 1, 4, str.tostring(cnt_prem) + (total > 0 ? "  " + str.tostring(math.round(cnt_prem / total * 100, 1)) + "%" : ""), text_color=color.red, text_size=size.tiny)

    table.cell(ts, 0, 5, "-- FILTERS --",   bgcolor=color.new(color.navy, 60), text_color=color.new(color.blue, 20), text_size=size.tiny)
    table.cell(ts, 1, 5, "",                bgcolor=color.new(color.navy, 60), text_color=color.gray, text_size=size.tiny)

    table.cell(ts, 0, 6, "Macro E2 blocked", text_color=color.gray, text_size=size.tiny)
    table.cell(ts, 1, 6, str.tostring(cnt_macro_blocked) + (not i_use_vix and not i_use_jpy ? "  [OFF]" : ""), text_color=i_use_vix or i_use_jpy ? color.orange : color.gray, text_size=size.tiny)

    table.cell(ts, 0, 7, "ADX E3 blocked",  text_color=color.gray, text_size=size.tiny)
    table.cell(ts, 1, 7, str.tostring(cnt_adx_blocked) + (not i_use_adx ? "  [OFF]" : ""), text_color=i_use_adx ? color.orange : color.gray, text_size=size.tiny)

    table.cell(ts, 0, 8, "RVOL E4 blocked", text_color=color.gray, text_size=size.tiny)
    table.cell(ts, 1, 8, str.tostring(cnt_rvol_blocked) + (not i_use_rvol ? "  [OFF]" : ""), text_color=i_use_rvol ? color.orange : color.gray, text_size=size.tiny)

    table.cell(ts, 0, 9, "SL / TP1 / TP2",  text_color=color.gray, text_size=size.tiny)
    table.cell(ts, 1, 9,
         str.tostring(i_atr_sl) + "x / " +
         str.tostring(i_atr_tp1) + "x / " +
         str.tostring(i_atr_tp2) + "x ATR",
         text_color=color.gray, text_size=size.tiny)